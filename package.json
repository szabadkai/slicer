{
  "name": "sla-slicer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "format:check": "prettier --check 'src/**/*.{ts,js}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-loc": "tsx scripts/check-loc.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@preact/signals-core": "^1.14.1",
    "fast-png": "^8.0.0",
    "jszip": "^3.10.1",
    "manifold-3d": "^3.4.1",
    "three": "^0.170.0",
    "three-mesh-bvh": "^0.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
